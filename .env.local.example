# Copy this file to ".env.local" and paste your OpenRouter API key below.
# Get a key at https://openrouter.ai/keys
#
# NOTE: This is a frontend-only app, so the key is exposed to the browser.
# Use a key with limited credit / spend caps for anything public.

NEXT_PUBLIC_OPENROUTER_API_KEY=sk-or-your-key-here

# Optional: override the default model used to write the stories.
NEXT_PUBLIC_OPENROUTER_MODEL=openai/gpt-oss-20b:free
